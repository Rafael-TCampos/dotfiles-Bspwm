# ────────────────
# Atalhos gerais (independente do WM)
# ────────────────

# abrir terminal
super + Return
    kitty

# abrir menu Rofi
super + d
    rofi -show drun

# recarregar configuração do sxhkd
super + Escape
    pkill -USR1 -x sxhkd

# ────────────────
# Atalhos BSPWM
# ────────────────

# fechar janela
super + q
    bspc node -c

# mover foco entre janelas
super + Left
    bspc node -f west
super + Down
    bspc node -f south
super + Up
    bspc node -f north
super + Right
    bspc node -f east

# mover janela entre direções
super + shift + Left
    bspc node -s west
super + shift + Down
    bspc node -s south
super + shift + Up
    bspc node -s north
super + shift + Right
    bspc node -s east

# Enviar janela para o Desktop no Monitor Principal (HDMI-0)
super + shift + {1,2,3,4,5}
    bspc node -d HDMI-0:^{1,2,3,4,5} -f

# Enviar janela para o Desktop no Monitor Secundário (DVI-0)
super + shift + {6,7,8,9,0}
    bspc node -d DVI-0:^{1,2,3,4,5} -f


# recarregar BSPWM (como i3 SUPER+Shift+R)
super + shift + r
    bspc wm -r

# Captura de tela Flameshot
super + p
    flameshot gui

# Atalho para Thunar
super + t
      thunar

       
# aumentar volume
ctrl + Up
    pamixer -i 5 && notify-send "Volume $(pamixer --get-volume)%"

# diminuir volume
ctrl + Down
    pamixer -d 5 && notify-send "Volume $(pamixer --get-volume)%"

# mute
ctrl + shift + m
    pamixer -t && notify-send "Mute"
