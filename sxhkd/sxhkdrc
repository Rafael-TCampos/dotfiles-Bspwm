# ────────────────
# Atalhos gerais (independente do WM)
# ────────────────

# abrir terminal
super + Return
    kitty

# abrir menu Rofi
super + d
    rofi -show drun

# recarregar configuração do sxhkd
super + Escape
    pkill -USR1 -x sxhkd

# ────────────────
# Atalhos BSPWM
# ────────────────

# fechar janela
super + q
    bspc node -c

# mover foco entre janelas
super + Left
    bspc node -f west
super + Down
    bspc node -f south
super + Up
    bspc node -f north
super + Right
    bspc node -f east

# mover janela entre direções
super + shift + Left
    bspc node -s west
super + shift + Down
    bspc node -s south
super + shift + Up
    bspc node -s north
super + shift + Right
    bspc node -s east

# --- MONITOR PRINCIPAL (HDMI-0) ---

# Focar Desktops (Trocar de área)
super + 1
    bspc desktop -f HDMI-0:^1
super + 2
    bspc desktop -f HDMI-0:^2
super + 3
    bspc desktop -f HDMI-0:^3
super + 4
    bspc desktop -f HDMI-0:^4
super + 5
    bspc desktop -f HDMI-0:^5

# Mover Janelas (Shift + Número)
super + shift + 1
    bspc node -d HDMI-0:^1 -f
super + shift + 2
    bspc node -d HDMI-0:^2 -f
super + shift + 3
    bspc node -d HDMI-0:^3 -f
super + shift + 4
    bspc node -d HDMI-0:^4 -f
super + shift + 5
    bspc node -d HDMI-0:^5 -f

# --- MONITOR SECUNDÁRIO (DVI-0) ---

# Focar Desktops (Trocar de área)
super + 6
    bspc desktop -f DVI-0:^1
super + 7
    bspc desktop -f DVI-0:^2
super + 8
    bspc desktop -f DVI-0:^3
super + 9
    bspc desktop -f DVI-0:^4
super + 0
    bspc desktop -f DVI-0:^5

# Mover Janelas (Shift + Número)
super + shift + 6
    bspc node -d DVI-0:^1 -f
super + shift + 7
    bspc node -d DVI-0:^2 -f
super + shift + 8
    bspc node -d DVI-0:^3 -f
super + shift + 9
    bspc node -d DVI-0:^4 -f
super + shift + 0
    bspc node -d DVI-0:^5 -f

# recarregar BSPWM (como i3 SUPER+Shift+R)
super + shift + r
    bspc wm -r

# Captura de tela Flameshot
super + p
    flameshot gui

# Atalho para Thunar
super + t
      thunar

       
# aumentar volume
ctrl + Up
    pamixer -i 5 && notify-send "Volume $(pamixer --get-volume)%"

# diminuir volume
ctrl + Down
    pamixer -d 5 && notify-send "Volume $(pamixer --get-volume)%"

# mute
ctrl + shift + m
    pamixer -t && notify-send "Mute"
